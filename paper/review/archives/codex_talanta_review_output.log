   310	  \caption{AOM mathematical structure.  AOM-PLS screens operators through
   311	  cross-covariances; AOM-Ridge screens operator-induced kernels.  Both recover
   312	  coefficients on the original wavelength grid.}
   313	  \label{fig:math}
   314	\end{figure}
