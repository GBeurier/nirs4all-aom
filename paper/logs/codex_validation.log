#include "aompls/c_api.h"
#include <math.h>
#include <stdio.h>
#include <stdlib.h>
int main() {
    aompls_config_t cfg; aompls_config_init(&cfg);
    cfg.max_components = 5;
    int n = 60, p = 50;
    double* X = malloc(sizeof(double)*n*p);
    double* y = malloc(sizeof(double)*n);
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < p; ++j) X[i*p+j] = (j == 10 ? 1.0 : 0.0) * (1.0 + 0.1 * i) + 0.01 * j;
        y[i] = 1.0 + 0.1 * i;
    }
    char* err = NULL;
    aompls_model_t* m = aompls_fit(X, n, p, y, &cfg, &err);
    if (!m) { fprintf(stderr, "FAIL: %s\n", err); aompls_free_string(err); return 1; }
    printf("selected=%s k=%d intercept=%.4f\n",
           aompls_selected_operator_name(m), aompls_n_components(m), aompls_get_intercept(m));
    double* pred = malloc(sizeof(double)*n);
    aompls_predict(m, X, n, pred, &err);
    double sse = 0; for (int i = 0; i < n; ++i) { double d = pred[i] - y[i]; sse += d*d; }
    printf("training RMSE: %.6f\n", sqrt(sse/n));
    aompls_free(m); free(X); free(y); free(pred); return 0;
}

